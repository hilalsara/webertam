@model IReadOnlyList<JobApplication>
@{ ViewData["Title"] = "Başvurularım"; }
<section class="section"><div class="container">
    <h1 class="section-title">Başvurularım</h1>
    <div class="table-responsive"><table class="table align-middle">
        <thead><tr><th>Pozisyon</th><th>Kod</th><th>Tarih</th><th>Durum</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        { <tr><td>@item.JobTitle</td><td>@item.ReferenceCode</td><td>@item.CreatedAt.ToString("dd.MM.yyyy")</td><td><span class="status-pill">@item.Status</span></td></tr> }
        </tbody>
    </table></div>
</div></section>
