@model StaffingRequestViewModel
@{ ViewData["Title"] = "Yeni Personel Talebi"; }
<section class="section"><div class="container"><div class="content-card mx-auto" style="max-width:850px">
    <h1 class="section-title">Yeni Personel Talebi</h1>
    <p class="text-muted">İhtiyacınızı ayrıntılı girin. Form Ertam yönetim paneline iletilerek veritabanında saklanır.</p>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-8"><label asp-for="PositionTitle"></label><input asp-for="PositionTitle" class="form-control" /><span asp-validation-for="PositionTitle" class="text-danger"></span></div>
            <div class="col-md-4"><label asp-for="PersonnelCount"></label><input asp-for="PersonnelCount" class="form-control" /><span asp-validation-for="PersonnelCount" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="WorkLocation"></label><input asp-for="WorkLocation" class="form-control" /><span asp-validation-for="WorkLocation" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="EmploymentType"></label><select asp-for="EmploymentType" class="form-select"><option>Tam Zamanlı</option><option>Yarı Zamanlı</option><option>Dönemsel</option><option>Proje Bazlı</option></select></div>
            <div class="col-12"><label asp-for="ShiftInfo"></label><input asp-for="ShiftInfo" class="form-control" placeholder="Örn. 3 vardiya / 08:00-16:00" /></div>
            <div class="col-12"><label asp-for="Qualifications"></label><textarea asp-for="Qualifications" class="form-control" rows="7"></textarea><span asp-validation-for="Qualifications" class="text-danger"></span></div>
            <div class="col-12"><label asp-for="Notes"></label><textarea asp-for="Notes" class="form-control" rows="4"></textarea></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button class="btn btn-brand">Talebi Ertam'a Gönder</button><a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a></div>
    </form>
</div></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
