<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ertam A.Ş.</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">E</span>
                    <span><strong>ERTAM A.Ş.</strong><small>İnsan Kaynakları & Danışmanlık</small></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li><a class="nav-link" asp-controller="Home" asp-action="Index">İş İlanları</a></li>
                        <li><a class="nav-link" asp-controller="Home" asp-action="Blog">Blog & Haberler</a></li>
                        <li><a class="nav-link" asp-controller="Home" asp-action="ApplicationStatus">Başvuru Sorgula</a></li>
                        <li><a class="nav-link" asp-controller="Home" asp-action="Contact">İletişim</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Factory"))
                            {
                                <li><a class="nav-link admin-link" asp-controller="Factory" asp-action="Index">Fabrika Talep Paneli</a></li>
                            }
                            else if (!User.IsInRole("Admin"))
                            {
                                <li><a class="nav-link" asp-controller="Applications" asp-action="MyApplications">Başvurularım</a></li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="nav-link admin-link" asp-controller="Admin" asp-action="Index">Admin Paneli</a></li>
                            }
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-brand btn-sm">Güvenli Çıkış</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a class="nav-link" asp-controller="Account" asp-action="Register">Kayıt Ol</a></li>
                            <li><a class="nav-link" asp-controller="Account" asp-action="FactoryRegister">Fabrika Kaydı</a></li>
                            <li><a class="btn btn-brand btn-sm" asp-controller="Account" asp-action="Login">Giriş Yap</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["Success"] is string message)
        {
            <div class="container pt-3"><div class="alert alert-success">@message</div></div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <h5>ERTAM A.Ş.</h5>
                    <p>İnsan odaklı, güvenilir ve sürdürülebilir istihdam çözümleri.</p>
                </div>
                <div class="col-md-3">
                    <h6>Hızlı Bağlantılar</h6>
                    <a asp-controller="Home" asp-action="Privacy">Gizlilik Politikası</a>
                    <a asp-controller="Home" asp-action="Blog">Blog & Haberler</a>
                    <a asp-controller="Home" asp-action="ApplicationStatus">Başvuru Sorgulama</a>
                    <a asp-controller="Account" asp-action="FactoryRegister">İşveren / Fabrika Portalı</a>
                </div>
                <div class="col-md-4">
                    <h6>İletişim</h6>
                    <p>Gebze / Kocaeli<br />+90 (530) 744 16 07<br />info@ertam-ik.com.tr</p>
                </div>
            </div>
            <div class="footer-bottom">© @DateTime.Now.Year Ertam A.Ş. Tüm hakları saklıdır.</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
