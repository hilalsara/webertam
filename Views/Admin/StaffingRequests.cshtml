@model IReadOnlyList<StaffingRequest>
@{ ViewData["Title"] = "Fabrika Personel Talepleri"; }
<section class="section"><div class="container-fluid px-lg-5 admin-shell">
    <partial name="_AdminNav" />
    <div>
        <h1 class="section-title">Fabrika Personel Talepleri</h1>
        @if (Model.Count == 0) { <div class="content-card">Henüz fabrika talebi bulunmuyor.</div> }
        <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12"><article class="content-card request-card"><div class="row g-3">
                <div class="col-lg-4"><h2 class="h5">@item.CompanyName</h2><p><strong>@item.PositionTitle</strong><br />@item.PersonnelCount kişi · @item.WorkLocation<br />@item.EmploymentType @item.ShiftInfo</p><small>@item.ContactName<br />@item.ContactEmail<br />@item.ContactPhone</small></div>
                <div class="col-lg-4"><strong>Aranan nitelikler</strong><p class="pre-line">@item.Qualifications</p>@if (!string.IsNullOrWhiteSpace(item.Notes)){<p><strong>Firma notu:</strong> @item.Notes</p>}</div>
                <div class="col-lg-4"><form asp-action="StaffingRequestStatus" method="post">
                    <input type="hidden" name="id" value="@item.Id" /><label class="form-label">Durum</label>
                    <select name="status" class="form-select mb-2">@foreach (var status in new[]{"Yeni","İnceleniyor","Firma ile Görüşüldü","Personel Aranıyor","Tamamlandı","İptal"}) { <option selected="@(item.Status == status)">@status</option> }</select>
                    <label class="form-label">Fabrikaya gösterilecek Ertam notu</label><textarea name="adminNote" class="form-control mb-2" rows="3">@item.AdminNote</textarea>
                    <button class="btn btn-brand">Talebi Güncelle</button>
                </form><small class="text-muted d-block mt-2">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small></div>
            </div></article></div>
        }
        </div>
    </div>
</div></section>
