@model BlogEditViewModel
@{ ViewData["Title"] = Model.Id == 0 ? "Yeni Blog/Haber" : "İçerik Düzenle"; }
<section class="section"><div class="container admin-shell">
    <partial name="_AdminNav" />
    <div class="content-card">
        <h1 class="section-title">@ViewData["Title"]</h1>
        <form method="post">
            <input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3"><label asp-for="Title"></label><input asp-for="Title" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Category"></label><input asp-for="Category" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Summary"></label><textarea asp-for="Summary" class="form-control" rows="3"></textarea></div>
            <div class="mb-3"><label asp-for="Content"></label><textarea asp-for="Content" class="form-control" rows="12"></textarea></div>
            <div class="form-check mb-3"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label"></label></div>
            <button class="btn btn-brand">Kaydet</button>
        </form>
    </div>
</div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
