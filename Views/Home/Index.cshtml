@model IEnumerable<ErtamIK.WebPortal.Models.Ilan>

@{
    ViewData["Title"] = "Ertam A.Ş. | Kariyer Kapısı";
}

<style>
    /* Genel Arka Plan - Sıcak fildişi/krem lüks tonu */
    body {
        background-color: #F8F5F0 !important;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Logo Konteyneri */
    .logo-container {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        margin-bottom: 20px;
        padding-left: 10px;
    }

    .brand-logo {
        height: 65px;
        object-fit: contain;
        filter: drop-shadow(0px 4px 8px rgba(0, 0, 0, 0.1));
    }

    /* Dinamik Arka Planlı Üst Banner (Hero) Alanı */
    .hero-banner-wrapper {
        position: relative;
        height: 320px;
        border-radius: 24px;
        margin-bottom: 40px;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(130, 4, 17, 0.15);
        border: 1px solid rgba(212, 175, 55, 0.3);
    }

    /* CSS ile Görsellerin Sürekli Dönmesi (İnşaat -> Temizlik -> Fabrika -> Elektrik) */
    .hero-slideshow {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    .slide {
        position: absolute;
        width: 100%;
        height: 100%;
        background-size: center/cover;
        background-position: center;
        opacity: 0;
        animation: slideShowAnim 24s infinite linear;
    }

        /* Görseller sırayla devreye giriyor (Her biri 6 saniye kalıyor) */
        .slide:nth-child(1) {
            background-image: url('https://images.unsplash.com/photo-1541888946425-d81bb19240f5?q=80&w=1200'); /* İnşaat */
            animation-delay: 0s;
        }

        .slide:nth-child(2) {
            background-image: url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?q=80&w=1200'); /* Temizlik */
            animation-delay: 6s;
        }

        .slide:nth-child(3) {
            background-image: url('https://images.unsplash.com/photo-1565465295423-68c959a593ba?q=80&w=1200'); /* Fabrika / Üretim */
            animation-delay: 12s;
        }

        .slide:nth-child(4) {
            background-image: url('https://images.unsplash.com/photo-1485827404703-89b55fcc595e?q=80&w=1200'); /* Elektrik / Otomasyon */
            animation-delay: 18s;
        }

    /* ASP.NET Çakışmasını Önlemek İçin Çift @@ Kullandık! */
    @@keyframes slideShowAnim {
        0% {
            opacity: 0;
            transform: scale(1);
        }

        4% {
            opacity: 1;
        }

        21% {
            opacity: 1;
        }

        25% {
            opacity: 0;
            transform: scale(1.05);
        }

        100% {
            opacity: 0;
        }
    }

    /* Görsellerin üzerine binen o şık vişne çürüğü/bordo transparan katman */
    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba(130, 4, 17, 0.2) 0%, rgba(130, 4, 17, 0.55) 100%);
        z-index: 2;
    }

    /* Banner İçeriği */
    .hero-content {
        position: relative;
        z-index: 3;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: 0 20px;
    }

    .hero-title {
        color: #ffffff;
        font-size: 2.4rem;
        font-weight: 700;
        text-shadow: 2px 2px 12px rgba(0, 0, 0, 0.7);
        margin-bottom: 20px;
        letter-spacing: 1px;
        text-align: center;
    }

    /* Minimal Arama Çubuğu */
    .search-box-container {
        width: 100%;
        max-width: 520px;
    }

    .search-box {
        border-radius: 50px;
        padding: 14px 25px;
        border: 1px solid rgba(212, 175, 55, 0.6);
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(10px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .search-box:focus {
            border-color: #D4AF37;
            box-shadow: 0 6px 25px rgba(130, 4, 17, 0.25);
        }

    /* Pinterest Tarzı İlan Kartları Grid Yapısı */
    .ilan-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 30px;
        padding-bottom: 60px;
    }

    /* Senin Seçtiğin Muhteşem Canlı Bordo (#820411) Kartlar */
    .ilan-kart {
        background-color: #820411;
        border-radius: 22px;
        padding: 25px;
        border: 1px solid rgba(212, 175, 55, 0.25);
        box-shadow: 0 12px 28px rgba(130, 4, 17, 0.18);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 290px;
    }

        /* Kartın Üzerine Gelince Süzülme Efekti */
        .ilan-kart:hover {
            transform: translateY(-10px);
            box-shadow: 0 18px 40px rgba(130, 4, 17, 0.35);
            border-color: #D4AF37;
        }

    /* Gold Yıldız Detayı */
    .gold-star {
        position: absolute;
        top: 22px;
        right: 22px;
        color: #D4AF37;
        font-size: 1.2rem;
    }

    .ilan-baslik {
        color: #ffffff;
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 8px;
        padding-right: 25px;
    }

    .ilan-konum {
        color: #D4AF37;
        font-size: 0.88rem;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Sektör Kapsülü (Badge) */
    .sektor-badge {
        background-color: rgba(212, 175, 55, 0.18);
        color: #D4AF37;
        border: 1px solid rgba(212, 175, 55, 0.35);
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 15px;
    }

    .ilan-detay {
        color: #FBF9F6;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 25px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Premium Oval Buton */
    .btn-basvur {
        background: transparent;
        color: #ffffff;
        border: 2px solid #ffffff;
        border-radius: 50px;
        padding: 11px 20px;
        font-size: 0.92rem;
        font-weight: 600;
        text-align: center;
        width: 100%;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
    }

        .btn-basvur:hover {
            background-color: #ffffff;
            color: #820411;
            box-shadow: 0 4px 18px rgba(255, 255, 255, 0.35);
        }
</style>

<div class="container mt-0">

    <div class="hero-banner-wrapper">
        <div class="hero-slideshow">
            <div class="slide"></div>
            <div class="slide"></div>
            <div class="slide"></div>
            <div class="slide"></div>
        </div>
        <div class="hero-overlay"></div>

        <div class="hero-content">
            <h1 class="hero-title">Geleceğinizi Ertam A.Ş. ile Şekillendirin.</h1>
            <div class="search-box-container">
                <input type="text" class="form-control search-box text-center" placeholder="Pozisyon, sektör veya şehir arayın...">
            </div>
        </div>
    </div>

    <div class="ilan-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var ilan in Model)
            {
                <div class="ilan-kart">
                    <div class="gold-star">★</div>

                    <div>
                        <h3 class="ilan-baslik">@ilan.txtIlanBasligi</h3>
                        <div class="ilan-konum">📍 @ilan.txtSehirIlce</div>
                        <span class="sektor-badge">@ilan.txtSektor</span>
                        <p class="ilan-detay">@ilan.txtIlanDetay</p>
                    </div>

                    <a href="#" class="btn-basvur">Detayları Gör & Başvur</a>
                </div>
            }
        }
        else
        {
            <div class="ilan-kart">
                <div class="gold-star">★</div>
                <div>
                    <h3 class="ilan-baslik">C# Backend Developer</h3>
                    <div class="ilan-konum">📍 Gebze / Kocaeli</div>
                    <span class="sektor-badge">Yazılım / Teknoloji</span>
                    <p class="ilan-detay">Ertam A.Ş. merkez ofisimizde görevlendirilmek üzere, WinForms ve ASP.NET mimarilerine hakim takım arkadaşları arıyoruz.</p>
                </div>
                <a href="#" class="btn-basvur">Detayları Gör & Başvur</a>
            </div>

            <div class="ilan-kart">
                <div class="gold-star">★</div>
                <div>
                    <h3 class="ilan-baslik">Saha Temizlik Şefi</h3>
                    <div class="ilan-konum">📍 Çayırova / Kocaeli</div>
                    <span class="sektor-badge">Temizlik Hizmetleri</span>
                    <p class="ilan-detay">Anlaşmalı olduğumuz fabrika projelerindeki temizlik ekiplerini sevk ve idare edecek, organizasyon yeteneği güçlü şef aranmaktadır.</p>
                </div>
                <a href="#" class="btn-basvur">Detayları Gör & Başvur</a>
            </div>

            <div class="ilan-kart">
                <div class="gold-star">★</div>
                <div>
                    <h3 class="ilan-baslik">İnşaat Proje Mühendisi</h3>
                    <div class="ilan-konum">📍 Merkez / Samsun</div>
                    <span class="sektor-badge">İnşaat / Taahhüt</span>
                    <p class="ilan-detay">Samsun bölgesindeki şantiye süreçlerimizi baştan sona yönetecek, hakediş ve saha kontrollerine hakim mühendis arayışımız mevcuttur.</p>
                </div>
                <a href="#" class="btn-basvur">Detayları Gör & Başvur</a>
            </div>
        }
    </div>
</div>