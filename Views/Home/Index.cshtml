@model HomeViewModel
@{
    ViewData["Title"] = "Kariyer Kapısı";
}

<section class="hero">
    <div class="container">
        <h1>Geleceğinizi Ertam A.Ş. ile şekillendirin</h1>
        <p>Güncel iş fırsatlarını keşfedin, güvenli hesabınızla başvurun ve sürecinizi çevrimiçi takip edin.</p>
        <a href="#ilanlar" class="btn btn-light btn-lg">Açık Pozisyonları Gör</a>
    </div>
</section>

<section class="section" id="ilanlar">
    <div class="container">
        <h2 class="section-title">Açık İş İlanları</h2>
        <form method="get" class="content-card job-filter mb-4">
            <div>
                <label for="search" class="form-label">Pozisyon veya sektör</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Örn. üretim, kaynakçı" />
            </div>
            <div>
                <label for="location" class="form-label">Şehir / İlçe</label>
                <input id="location" name="location" value="@Model.Location" class="form-control" placeholder="Örn. Gebze" />
            </div>
            <button class="btn btn-brand">İlanları Filtrele</button>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Location))
            {
                <a asp-action="Index" asp-fragment="ilanlar" class="btn btn-outline-secondary">Temizle</a>
            }
        </form>
        <div class="row g-4">
            @if (Model.Jobs.Count == 0)
            {
                <div class="col-12"><div class="content-card">Şu anda aktif ilan bulunmuyor. Yeni fırsatlar için bizi takip edin.</div></div>
            }
            @foreach (var job in Model.Jobs)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="job-card d-flex flex-column">
                        <span class="badge-sector align-self-start">@job.txtSektor</span>
                        <h3 class="mt-3">@job.txtIlanBasligi</h3>
                        <p class="text-muted">📍 @job.txtSehirIlce</p>
                        <p class="flex-grow-1">@job.txtIlanDetay</p>
                        <a class="btn btn-brand" asp-controller="Applications" asp-action="Apply" asp-route-id="@job.Id">Detayları Gör & Başvur</a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section bg-white">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title mb-0">Blog & Haberler</h2>
            <a asp-action="Blog">Tümünü Gör →</a>
        </div>
        <div class="row g-4">
            @foreach (var post in Model.Posts)
            {
                <div class="col-md-4">
                    <article class="content-card">
                        <small class="text-muted">@post.Category · @post.PublishedAt.ToString("dd.MM.yyyy")</small>
                        <h3 class="h5 mt-2">@post.Title</h3>
                        <p>@post.Summary</p>
                        <a asp-action="BlogDetail" asp-route-id="@post.Id">Devamını oku</a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
